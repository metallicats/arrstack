# ============================================================
# AIOStreams Environment Variables
# Generate SECRET_KEY with: openssl rand -hex 32
# ============================================================

SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_KEY

ADDON_NAME=AIOStreams

# Proxy config to bypass Oracle IP blocks on Torrentio/strem.fun
ADDON_PROXY=http://warp:1080
ADDON_PROXY_CONFIG=*:false,*.strem.fun:true

PORT=3000
